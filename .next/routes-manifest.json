{
  "version": 3,
  "pages404": true,
  "appType": "app",
  "caseSensitive": false,
  "basePath": "/next",
  "redirects": [
    {
      "source": "/next/",
      "destination": "/next",
      "basePath": false,
      "internal": true,
      "priority": true,
      "statusCode": 308,
      "regex": "^/next/$"
    },
    {
      "source": "/:path+/",
      "destination": "/:path+",
      "internal": true,
      "priority": true,
      "statusCode": 308,
      "regex": "^(?:/((?:[^/]+?)(?:/(?:[^/]+?))*))/$"
    }
  ],
  "headers": [],
  "rewrites": {
    "beforeFiles": [],
    "afterFiles": [
      {
        "source": "/next/services/development",
        "destination": "/next/community/services/development",
        "regex": "^/next/services/development(?:/)?$"
      },
      {
        "source": "/next/features",
        "destination": "/next/community/features",
        "regex": "^/next/features(?:/)?$"
      },
      {
        "source": "/next/docs",
        "destination": "/next/community/docs",
        "regex": "^/next/docs(?:/)?$"
      },
      {
        "source": "/next/docs/:path*",
        "destination": "/next/community/docs/:path*",
        "regex": "^/next/docs(?:/((?:[^/]+?)(?:/(?:[^/]+?))*))?(?:/)?$"
      },
      {
        "source": "/next/convert_national_market",
        "destination": "/next/community/services/national_market",
        "regex": "^/next/convert_national_market(?:/)?$"
      },
      {
        "source": "/next/support",
        "destination": "/next/community/services/support_page",
        "regex": "^/next/support(?:/)?$"
      },
      {
        "source": "/next/hustadmin",
        "destination": "/next/shop/hustadmin",
        "regex": "^/next/hustadmin(?:/)?$"
      },
      {
        "source": "/next/hustadmin/:path*",
        "destination": "/next/shop/hustadmin/:path*",
        "regex": "^/next/hustadmin(?:/((?:[^/]+?)(?:/(?:[^/]+?))*))?(?:/)?$"
      },
      {
        "source": "/next/check/:slug",
        "destination": "/next/shop/scams_check/profile/:slug",
        "regex": "^/next/check(?:/([^/]+?))(?:/)?$"
      },
      {
        "source": "/next/check/:path*",
        "destination": "/next/shop/scams_check/:path*",
        "regex": "^/next/check(?:/((?:[^/]+?)(?:/(?:[^/]+?))*))?(?:/)?$"
      },
      {
        "source": "/next/orders_once/:slug_2",
        "destination": "/next/shop/ai?slug_2=:slug_2",
        "regex": "^/next/orders_once(?:/([^/]+?))(?:/)?$"
      },
      {
        "source": "/next/shop/ai/:slug_2",
        "destination": "/next/shop/ai?slug_2=:slug_2",
        "regex": "^/next/shop/ai(?:/([^/]+?))(?:/)?$"
      }
    ],
    "fallback": []
  },
  "dynamicRoutes": [
    {
      "page": "/accounts/product/play/[slug]",
      "regex": "^/accounts/product/play/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPslug": "nxtPslug"
      },
      "namedRegex": "^/accounts/product/play/(?<nxtPslug>[^/]+?)(?:/)?$"
    },
    {
      "page": "/api/features-image/[...asset]",
      "regex": "^/api/features\\-image/(.+?)(?:/)?$",
      "routeKeys": {
        "nxtPasset": "nxtPasset"
      },
      "namedRegex": "^/api/features\\-image/(?<nxtPasset>.+?)(?:/)?$"
    },
    {
      "page": "/community/docs/[slug]",
      "regex": "^/community/docs/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPslug": "nxtPslug"
      },
      "namedRegex": "^/community/docs/(?<nxtPslug>[^/]+?)(?:/)?$"
    },
    {
      "page": "/community/services/[service]",
      "regex": "^/community/services/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPservice": "nxtPservice"
      },
      "namedRegex": "^/community/services/(?<nxtPservice>[^/]+?)(?:/)?$"
    },
    {
      "page": "/resource/product/play/[slug]",
      "regex": "^/resource/product/play/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPslug": "nxtPslug"
      },
      "namedRegex": "^/resource/product/play/(?<nxtPslug>[^/]+?)(?:/)?$"
    },
    {
      "page": "/resources/play/[slug]",
      "regex": "^/resources/play/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPslug": "nxtPslug"
      },
      "namedRegex": "^/resources/play/(?<nxtPslug>[^/]+?)(?:/)?$"
    },
    {
      "page": "/resources/[[...segments]]",
      "regex": "^/resources(?:/(.+?))?(?:/)?$",
      "routeKeys": {
        "nxtPsegments": "nxtPsegments"
      },
      "namedRegex": "^/resources(?:/(?<nxtPsegments>.+?))?(?:/)?$"
    },
    {
      "page": "/shop/scams_check/profile/[slug]",
      "regex": "^/shop/scams_check/profile/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPslug": "nxtPslug"
      },
      "namedRegex": "^/shop/scams_check/profile/(?<nxtPslug>[^/]+?)(?:/)?$"
    },
    {
      "page": "/shop/scams_check/[slug]",
      "regex": "^/shop/scams_check/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPslug": "nxtPslug"
      },
      "namedRegex": "^/shop/scams_check/(?<nxtPslug>[^/]+?)(?:/)?$"
    }
  ],
  "staticRoutes": [
    {
      "page": "/",
      "regex": "^/(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/(?:/)?$"
    },
    {
      "page": "/_global-error",
      "regex": "^/_global\\-error(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/_global\\-error(?:/)?$"
    },
    {
      "page": "/_not-found",
      "regex": "^/_not\\-found(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/_not\\-found(?:/)?$"
    },
    {
      "page": "/api/resources/services-info",
      "regex": "^/api/resources/services\\-info(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/api/resources/services\\-info(?:/)?$"
    },
    {
      "page": "/community/features",
      "regex": "^/community/features(?:/)?$",
