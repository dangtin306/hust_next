      "namedRegex": "^/info/private_policy(?:/)?$"
    },
    {
      "page": "/info/seo_media",
      "regex": "^/info/seo_media(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/info/seo_media(?:/)?$"
    },
    {
      "page": "/info/terms_service",
      "regex": "^/info/terms_service(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/info/terms_service(?:/)?$"
    },
    {
      "page": "/shop/ai",
      "regex": "^/shop/ai(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/shop/ai(?:/)?$"
    },
    {
      "page": "/shop/hustadmin/scheduler",
      "regex": "^/shop/hustadmin/scheduler(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/shop/hustadmin/scheduler(?:/)?$"
    },
    {
      "page": "/shop/resources",
      "regex": "^/shop/resources(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/shop/resources(?:/)?$"
    },
    {
      "page": "/tabs_nav/navConfig.json",
      "regex": "^/tabs_nav/navConfig\\.json(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/tabs_nav/navConfig\\.json(?:/)?$"
    },
    {
      "page": "/tabs_nav/tabs_nav.json",
      "regex": "^/tabs_nav/tabs_nav\\.json(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/tabs_nav/tabs_nav\\.json(?:/)?$"
    }
  ],
  "dataRoutes": [],
  "rsc": {
    "header": "rsc",
    "varyHeader": "rsc, next-router-state-tree, next-router-prefetch, next-router-segment-prefetch",
    "prefetchHeader": "next-router-prefetch",
    "didPostponeHeader": "x-nextjs-postponed",
    "contentTypeHeader": "text/x-component",
    "suffix": ".rsc",
    "prefetchSegmentHeader": "next-router-segment-prefetch",
    "prefetchSegmentSuffix": ".segment.rsc",
    "prefetchSegmentDirSuffix": ".segments",
    "clientParamParsing": false,
    "dynamicRSCPrerender": false
  },
  "rewriteHeaders": {
    "pathHeader": "x-nextjs-rewritten-path",
    "queryHeader": "x-nextjs-rewritten-query"
  }
}